{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "created": { "type": "string" },
    "patternCount": { "type": "integer" },
    "songCount": { "type": "integer" },
    "drumkitCount": { "type": "integer" },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "url", "hash", "author", "description", "version", "formatVersion", "tags", "size", "license", "notes", "instrumentTypes"],
        "properties": {
          "type": { "const": "pattern" },
          "name": { "type": "string" },
          "url": { "type": "string" },
          "hash": { "type": "string" },
          "author": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "integer" },
          "formatVersion": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "size": { "type": "integer" },
          "license": { "type": "string" },
          "notes": { "type": "integer" },
          "instrumentTypes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "songs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "url", "hash", "author", "description", "version", "formatVersion", "tags", "size", "license", "patterns"],
        "properties": {
          "type": { "const": "song" },
          "name": { "type": "string" },
          "url": { "type": "string" },
          "hash": { "type": "string" },
          "author": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "integer" },
          "formatVersion": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "size": { "type": "integer" },
          "license": { "type": "string" },
          "patterns": { "type": "integer" }
        }
      }
    },
    "drumkits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "url", "hash", "author", "description", "version", "formatVersion", "tags", "size", "license", "instruments", "components", "samples", "instrumentTypes"],
        "properties": {
          "type": { "const": "drumkit" },
          "name": { "type": "string" },
          "url": { "type": "string" },
          "hash": { "type": "string" },
          "author": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "integer" },
          "formatVersion": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "size": { "type": "integer" },
          "license": { "type": "string" },
          "instruments": { "type": "integer" },
          "components": { "type": "integer" },
          "samples": { "type": "integer" },
          "instrumentTypes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "hash": { "type": "string" }
  },
  "required": ["version", "created", "patternCount", "songCount", "drumkitCount", "patterns", "songs", "drumkits", "hash"]
}
