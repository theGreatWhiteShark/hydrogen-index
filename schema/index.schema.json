{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thegreatwhiteshark.github.io/hydrogen-index/schema/index.schema.json",
  "title": "hydrogen-index index.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "created",
    "patternCount",
    "songCount",
    "drumkitCount",
    "patterns",
    "songs",
    "drumkits"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$"
    },
    "patternCount": {
      "type": "integer",
      "minimum": 0
    },
    "songCount": {
      "type": "integer",
      "minimum": 0
    },
    "drumkitCount": {
      "type": "integer",
      "minimum": 0
    },
    "patterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patternArtifact"
      }
    },
    "songs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/songArtifact"
      }
    },
    "drumkits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/drumkitArtifact"
      }
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "patternArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "url",
        "hash",
        "author",
        "description",
        "version",
        "formatVersion",
        "tags",
        "size",
        "license",
        "notes",
        "instrumentTypes"
      ],
      "properties": {
        "type": {
          "const": "pattern"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "author": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 0
        },
        "formatVersion": {
          "type": "integer",
          "minimum": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "license": {
          "type": "string"
        },
        "notes": {
          "type": "integer",
          "minimum": 0
        },
        "instrumentTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "songArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "url",
        "hash",
        "author",
        "description",
        "version",
        "formatVersion",
        "tags",
        "size",
        "license",
        "patterns"
      ],
      "properties": {
        "type": {
          "const": "song"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "author": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 0
        },
        "formatVersion": {
          "type": "integer",
          "minimum": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "license": {
          "type": "string"
        },
        "patterns": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "drumkitArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "url",
        "hash",
        "author",
        "description",
        "version",
        "formatVersion",
        "tags",
        "size",
        "license",
        "instruments",
        "components",
        "samples",
        "instrumentTypes"
      ],
      "properties": {
        "type": {
          "const": "drumkit"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "author": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 0
        },
        "formatVersion": {
          "type": "integer",
          "minimum": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "license": {
          "type": "string"
        },
        "instruments": {
          "type": "integer",
          "minimum": 0
        },
        "components": {
          "type": "integer",
          "minimum": 0
        },
        "samples": {
          "type": "integer",
          "minimum": 0
        },
        "instrumentTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
